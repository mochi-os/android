    <string name="reauth_channel_name">Mochi: ಸೈನ್ ಇನ್ ಅಗತ್ಯವಿದೆ</string>
    <string name="reauth_channel_description">ನಿಮ್ಮ ಸೆಷನ್ ಅನೂರ್ಜಿತಗೊಳಿಸಲ್ಪಟ್ಟಿರುವುದರಿಂದ Mochi ನಿಮ್ಮ ಸರ್ವರ್ ಅನ್ನು ತಲುಪಲು ಸಾಧ್ಯವಾಗದಿದ್ದಾಗ ಕಾಣಿಸಿಕೊಳ್ಳುತ್ತದೆ</string>
