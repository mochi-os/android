<?xml version="1.0" encoding="utf-8"?>
<!--
  Mochi shell app. Source lives at apps/menu/android/ to match the menu Mochi
  app convention; the Android package is org.mochios.mochi to match the
  user-facing "Mochi" launcher brand.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"
        xmlns:tools="http://schemas.android.com/tools" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".MochiApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Mochi">

        <!--
          MainActivity has NO MAIN/LAUNCHER intent-filter — the per-app
          activity-aliases below own those, so Android shows one launcher
          entry per Mochi-app instead of a single 'Mochi' icon. MainActivity
          still catches mochi://notification (tapped system notification)
          and the upcoming mochi://oauth-return (task #133).
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Mochi">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!--
                  Single broad filter — claim all `mochi:` URIs. The
                  super-app routes by slash count in MainActivity.
                  See claude/plans/mochi-uri-scheme.md.
                -->
                <data android:scheme="mochi" />
            </intent-filter>
        </activity>

        <!--
          Per-app activity-aliases. Each shows up as its own launcher icon
          (Mochi Feeds / Mochi Chat / Mochi Forums / Mochi Projects). All
          point at MainActivity; the alias's org.mochios.targetApp meta-data
          tells MainActivity which Mochi-app's nav graph to start in.
          Adaptive icons per app land in task #132.
        -->
        <activity-alias
            android:name=".MochiFeedsLauncher"
            android:enabled="true"
            android:exported="true"
            android:label="@string/launcher_feeds"
            android:icon="@mipmap/ic_feeds"
            android:roundIcon="@mipmap/ic_feeds_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data android:name="org.mochios.targetApp" android:value="feeds" />
        </activity-alias>

        <activity-alias
            android:name=".MochiChatLauncher"
            android:enabled="true"
            android:exported="true"
            android:label="@string/launcher_chat"
            android:icon="@mipmap/ic_chat"
            android:roundIcon="@mipmap/ic_chat_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data android:name="org.mochios.targetApp" android:value="chat" />
        </activity-alias>

        <activity-alias
            android:name=".MochiForumsLauncher"
            android:enabled="true"
            android:exported="true"
            android:label="@string/launcher_forums"
            android:icon="@mipmap/ic_forums"
            android:roundIcon="@mipmap/ic_forums_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data android:name="org.mochios.targetApp" android:value="forums" />
        </activity-alias>

        <activity-alias
            android:name=".MochiProjectsLauncher"
            android:enabled="true"
            android:exported="true"
            android:label="@string/launcher_projects"
            android:icon="@mipmap/ic_projects"
            android:roundIcon="@mipmap/ic_projects_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data android:name="org.mochios.targetApp" android:value="projects" />
        </activity-alias>

        <activity-alias
            android:name=".MochiSettingsLauncher"
            android:enabled="true"
            android:exported="true"
            android:label="@string/launcher_settings"
            android:icon="@mipmap/ic_settings"
            android:roundIcon="@mipmap/ic_settings_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data android:name="org.mochios.targetApp" android:value="settings" />
        </activity-alias>

        <!--
          UnifiedPush MessagingReceiver for the consolidated super-app. Catches
          MESSAGE / NEW_ENDPOINT / UNREGISTERED / REGISTRATION_FAILED broadcasts
          from PushService and posts a system notification on the right per-app
          channel (routed by the deep-link's first path segment in
          MochiPushDispatcher.channelId). Replaces the four per-app
          XxxPushReceiver classes that existed when feeds / chat / forums /
          projects shipped as separate APKs.
        -->
        <receiver
            android:name=".push.MochiPushDispatcher"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="org.unifiedpush.android.connector.MESSAGE" />
                <action android:name="org.unifiedpush.android.connector.UNREGISTERED" />
                <action android:name="org.unifiedpush.android.connector.NEW_ENDPOINT" />
                <action android:name="org.unifiedpush.android.connector.REGISTRATION_FAILED" />
            </intent-filter>
        </receiver>

        <!--
          UnifiedPush distributor receiver. The class lives in lib/android
          and is shared by every Mochi-signed app, but only this shell
          declares it in its manifest so the system distributor picker
          shows a single "Mochi" candidate. Per-app apps (Feeds, Chat,
          Forums, Projects) deliberately do NOT include this receiver.
          See claude/plans/android-notifications.md → "Manifest additions"
          and lib/android/src/distributor/AndroidManifest.xml (template).
        -->
        <receiver
            android:name="org.mochios.android.push.MochiDistributorReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="org.unifiedpush.android.distributor.REGISTER" />
                <action android:name="org.unifiedpush.android.distributor.UNREGISTER" />
                <action android:name="org.unifiedpush.android.distributor.MESSAGE_ACK" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="org.mochios.android.push.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!--
          File provider that hands the downloaded update APK to the system
          installer. The APK lives in cacheDir/updates/ and is exposed read-
          only via update_paths.xml; the FLAG_GRANT_READ_URI_PERMISSION on
          the install intent gives the installer transient access without
          needing a runtime permission.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.updates"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/update_paths" />
        </provider>

        <service
            android:name="org.mochios.android.push.PushService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="UnifiedPush message bridge for Mochi" />
        </service>

        <!--
          FCM receiver. Only fires when the Mochi server admin has pasted
          their Firebase config into system settings AND the client has
          successfully registered a token against it. When FCM is in use
          the listening notification (PushService) is not started.
        -->
        <service
            android:name="org.mochios.android.push.MochiFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
